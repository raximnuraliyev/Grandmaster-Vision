    // =====================================================
    // CHESS CLOCK
    // =====================================================

    private void StartClock()
    {
        if (_clockRunning) return;

        _clockRunning = true;
        _lastTickTime = DateTime.UtcNow;
        _clockTimer = new System.Threading.Timer(OnClockTick, null, 0, 100); // 100ms interval for smooth display
    }

    private void PauseClock()
    {
        _clockRunning = false;
        _clockTimer?.Dispose();
        _clockTimer = null;
    }

    private void ResetClocks()
    {
        PauseClock();
        _whiteTime = TimeSpan.FromMinutes(10);
        _blackTime = TimeSpan.FromMinutes(10);
    }

    private void OnClockTick(object? state)
    {
        if (!_clockRunning) return;

        var now = DateTime.UtcNow;
        var elapsed = now - _lastTickTime;
        _lastTickTime = now;

        var position = FenParser.TryParse(_currentFen);
        if (position == null) return;

        if (position.WhiteToMove)
        {
            _whiteTime -= elapsed;
            if (_whiteTime < TimeSpan.Zero) _whiteTime = TimeSpan.Zero;
        }
        else
        {
            _blackTime -= elapsed;
            if (_blackTime < TimeSpan.Zero) _blackTime = TimeSpan.Zero;
        }

        // Flag time (for future: handle game loss on time)
        if (_whiteTime <= TimeSpan.Zero || _blackTime <= TimeSpan.Zero)
        {
            PauseClock();
        }

        InvokeAsync(StateHasChanged);
    }

    // =====================================================
    // COACH MOVE EXPLANATION
    // =====================================================

    private async Task GenerateCoachExplanation(double? evalBefore, double? evalAfter, string playerMove, string bestMove)
    {
        _coachExplanation = null;

        if (!evalBefore.HasValue || !evalAfter.HasValue) return;

        var evalDrop = evalBefore.Value - evalAfter.Value;
        var isWhiteMove = !FenParser.TryParse(_currentFen)?.WhiteToMove ?? true;

        // Adjust for black's perspective
        if (!isWhiteMove) evalDrop = -evalDrop;

        // Classify the move
        if (evalDrop >= 3.0)
        {
            _lastMoveEvalClassification = MoveClassification.Blunder;
            _coachExplanation = $"This was a blunder! You lost {evalDrop:F1} pawns worth of advantage. The best move was {bestMove}.";
        }
        else if (evalDrop >= 1.5)
        {
            _lastMoveEvalClassification = MoveClassification.Mistake;
            _coachExplanation = $"This was a mistake. You gave away {evalDrop:F1} pawns. Consider {bestMove} instead.";
        }
        else if (evalDrop >= 0.5)
        {
            _lastMoveEvalClassification = MoveClassification.Inaccuracy;
            _coachExplanation = $"This move is slightly inaccurate. {bestMove} was more precise.";
        }
        else if (playerMove == bestMove)
        {
            _lastMoveEvalClassification = MoveClassification.Best;
            _coachExplanation = "Excellent! This is the best move in the position.";
        }
        else
        {
            _lastMoveEvalClassification = MoveClassification.Good;
            _coachExplanation = "This is a reasonable move. The computer suggests " + bestMove + " as slightly better.";
        }

        // Update the last move in history with classification
        if (_currentMoveIndex >= 0 && _currentMoveIndex < _moveHistory.Count)
        {
            _moveHistory[_currentMoveIndex].Classification = _lastMoveEvalClassification;
            _moveHistory[_currentMoveIndex].Evaluation = evalAfter;
        }
    }

