@page "/"
@using GrandmasterVision.Client.Components
@using GrandmasterVision.Client.Services
@using GrandmasterVision.Core.Services
@inject ChessApiService ApiService

<PageTitle>Grandmaster Vision - AI Chess Analysis</PageTitle>

<div class="analysis-grid">
    <div class="board-section">
        <ChessBoard @key="_boardKey"
                    Fen="@_currentFen"
                    Evaluation="@_evaluation"
                    MateIn="@_mateIn"
                    OnMove="HandleMove"
                    FlipBoard="@_flipBoard" />

        <div class="board-controls">
            <button class="btn btn-secondary" @onclick="FlipBoard">
                ⟲ Flip
            </button>
            <button class="btn btn-secondary" @onclick="ResetBoard">
                ↺ Reset
            </button>
            <button class="btn btn-primary" @onclick="Analyze" disabled="@_isAnalyzing">
                @if (_isAnalyzing)
                {
                    <span>⏳ Analyzing...</span>
                }
                else
                {
                    <span>⚡ Analyze</span>
                }
            </button>
        </div>

        <!-- Position Stats -->
        <div class="position-stats">
            <div class="stat">
                <span class="stat-label">Turn</span>
                <span class="stat-value">@(GetCurrentTurn())</span>
            </div>
            <div class="stat">
                <span class="stat-label">Material</span>
                <span class="stat-value @GetMaterialClass()">@GetMaterialBalance()</span>
            </div>
            <div class="stat">
                <span class="stat-label">Move</span>
                <span class="stat-value">@GetMoveNumber()</span>
            </div>
        </div>
    </div>

    <div class="analysis-panel">
        <!-- Evaluation Card -->
        <div class="card">
            <div class="card-header">
                <span class="card-title"><span class="icon icon-eval"></span> Evaluation</span>
                @if (_analysisDepth > 0)
                {
                    <span class="badge badge-success">Depth @_analysisDepth</span>
                }
            </div>
            <div class="card-body">
                <div class="eval-bar-container">
                    <div class="eval-bar">
                        <div class="eval-bar-fill" style="width: @GetEvalBarWidth()%"></div>
                    </div>
                    <div class="eval-value @GetEvalClass()">@FormatEval(_evaluation, _mateIn)</div>
                </div>
            </div>
        </div>

        <!-- Top Moves Card -->
        @if (_topMoves != null && _topMoves.Count > 0)
        {
            <div class="card">
                <div class="card-header">
                    <span class="card-title"><span class="icon icon-moves"></span> Best Moves</span>
                </div>
                <div class="card-body">
                    <div class="move-list">
                        @foreach (var move in _topMoves)
                        {
                            <div class="move-item @(move.Rank == 1 ? "best" : "")">
                                <div class="move-rank">@move.Rank</div>
                                <span class="move-name">@move.Move</span>
                                <span class="move-eval">@FormatEval(move.Evaluation, move.MateIn)</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Principal Variation -->
        @if (_bestMove?.PrincipalVariation != null)
        {
            <div class="card">
                <div class="card-header">
                    <span class="card-title"><span class="icon icon-pv"></span> Best Line</span>
                </div>
                <div class="card-body">
                    <div class="pv-line">@_bestMove.PrincipalVariation</div>
                </div>
            </div>
        }

        <!-- Opening Info -->
        @if (_opening != null)
        {
            <div class="card">
                <div class="card-header">
                    <span class="card-title"><span class="icon icon-book"></span> Opening</span>
                </div>
                <div class="card-body">
                    <div class="opening-info">
                        <span class="opening-eco">@_opening.Eco</span>
                        <span class="opening-name">@_opening.Name</span>
                    </div>
                </div>
            </div>
        }

        <!-- FEN Input -->
        <div class="card">
            <div class="card-header">
                <span class="card-title"><span class="icon icon-fen"></span> Position (FEN)</span>
            </div>
            <div class="card-body">
                <div class="input-group">
                    <input type="text" class="input" @bind="_fenInput" placeholder="Paste FEN notation..." />
                    <button class="btn btn-secondary" @onclick="LoadFen">Load</button>
                </div>
            </div>
        </div>

        <!-- File Upload -->
        <div class="card">
            <div class="card-header">
                <span class="card-title"><span class="icon icon-upload"></span> Import Board</span>
            </div>
            <div class="card-body">
                <div class="upload-zone">
                    <InputFile OnChange="HandleFileUpload" accept="image/*,.pgn" />
                    <div class="upload-icon">📷</div>
                    <div class="upload-text">Drop screenshot or PGN</div>
                    <div class="upload-hint">PNG, JPG, or PGN files</div>
                </div>
            </div>
        </div>

        <!-- Coach Message -->
        @if (!string.IsNullOrEmpty(_coachMessage))
        {
            <div class="card coach-card">
                <div class="card-header">
                    <span class="card-title"><span class="icon icon-coach"></span> Coach</span>
                </div>
                <div class="card-body">
                    <p class="coach-message">@_coachMessage</p>
                </div>
            </div>
        }

        <!-- Analyzing State -->
        @if (_isAnalyzing)
        {
            <div class="analyzing-state">
                <div class="spinner"></div>
                <span class="analyzing-text">Stockfish analyzing... Depth @_analysisDepth</span>
            </div>
        }
    </div>
</div>

@code {
    private string _currentFen = FenParser.StartingPosition;
    private string _fenInput = FenParser.StartingPosition;
    private bool _flipBoard = false;
    private bool _isAnalyzing = false;
    private int _analysisDepth = 0;
    private int _boardKey = 0;

    private double? _evaluation;
    private int? _mateIn;
    private BestMoveResponse? _bestMove;
    private List<MoveAnalysis>? _topMoves;
    private OpeningInfo? _opening;
    private string? _coachMessage;

    protected override void OnInitialized()
    {
        _coachMessage = "Welcome! Upload a chess board image or enter a FEN position, then click Analyze.";
    }

    private void FlipBoard() => _flipBoard = !_flipBoard;

    private void ResetBoard()
    {
        _currentFen = FenParser.StartingPosition;
        _fenInput = FenParser.StartingPosition;
        _evaluation = null;
        _mateIn = null;
        _bestMove = null;
        _topMoves = null;
        _opening = null;
        _analysisDepth = 0;
        _boardKey++; // Force ChessBoard component to re-create
        _coachMessage = "Board reset to starting position.";
        StateHasChanged();
    }

    private async Task LoadFen()
    {
        // Client-side validation first
        var (isValid, error) = FenParser.Validate(_fenInput);
        if (!isValid)
        {
            _coachMessage = $"Invalid FEN: {error}";
            StateHasChanged();
            return;
        }

        _currentFen = _fenInput;
        _coachMessage = "Position loaded successfully. Click Analyze to evaluate.";
        StateHasChanged();

        await TryIdentifyOpening();
    }

    private async Task Analyze()
    {
        if (_isAnalyzing) return;

        _isAnalyzing = true;
        _analysisDepth = 0;
        _coachMessage = "Starting deep analysis with Stockfish...";
        StateHasChanged();

        try
        {
            // Run both in parallel
            var topMovesTask = ApiService.GetTopMovesAsync(_currentFen, 3, 20);
            var bestMoveTask = ApiService.GetBestMoveAsync(_currentFen, 20);
            var openingTask = TryIdentifyOpening();

            await Task.WhenAll(topMovesTask, bestMoveTask, openingTask);

            _topMoves = await topMovesTask;
            _bestMove = await bestMoveTask;

            if (_bestMove != null)
            {
                _evaluation = _bestMove.Evaluation;
                _mateIn = _bestMove.MateIn;
                _analysisDepth = _bestMove.Depth;
            }

            GenerateCoachMessage();
        }
        catch (Exception ex)
        {
            _coachMessage = $"Analysis failed: {ex.Message}. Make sure the API is running.";
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }

    private async Task TryIdentifyOpening()
    {
        try
        {
            _opening = await ApiService.IdentifyOpeningAsync(_currentFen);
        }
        catch
        {
            _opening = null;
        }
    }

    private async Task HandleMove(string move)
    {
        // Parse current position and apply the move
        var position = FenParser.TryParse(_currentFen);
        if (position == null)
        {
            _coachMessage = "Invalid position state.";
            return;
        }

        // Parse move (e.g., "e2e4")
        if (move.Length < 4)
        {
            _coachMessage = $"Invalid move format: {move}";
            return;
        }

        var fromSquare = move.Substring(0, 2);
        var toSquare = move.Substring(2, 2);

        // Get the piece being moved
        var piece = position.GetPieceAt(fromSquare);
        if (piece == Piece.None)
        {
            _coachMessage = $"No piece at {fromSquare}";
            return;
        }

        // Apply the move
        position.SetPieceAt(fromSquare, Piece.None);
        position.SetPieceAt(toSquare, piece);

        // Handle castling
        if (piece == Piece.WhiteKing && fromSquare == "e1")
        {
            if (toSquare == "g1") { position.SetPieceAt("h1", Piece.None); position.SetPieceAt("f1", Piece.WhiteRook); }
            else if (toSquare == "c1") { position.SetPieceAt("a1", Piece.None); position.SetPieceAt("d1", Piece.WhiteRook); }
            position.WhiteKingsideCastle = false;
            position.WhiteQueensideCastle = false;
        }
        else if (piece == Piece.BlackKing && fromSquare == "e8")
        {
            if (toSquare == "g8") { position.SetPieceAt("h8", Piece.None); position.SetPieceAt("f8", Piece.BlackRook); }
            else if (toSquare == "c8") { position.SetPieceAt("a8", Piece.None); position.SetPieceAt("d8", Piece.BlackRook); }
            position.BlackKingsideCastle = false;
            position.BlackQueensideCastle = false;
        }

        // Handle pawn promotion (default to queen)
        if (piece == Piece.WhitePawn && toSquare[1] == '8')
            position.SetPieceAt(toSquare, move.Length > 4 ? GetPromotionPiece(move[4], true) : Piece.WhiteQueen);
        else if (piece == Piece.BlackPawn && toSquare[1] == '1')
            position.SetPieceAt(toSquare, move.Length > 4 ? GetPromotionPiece(move[4], false) : Piece.BlackQueen);

        // Handle en passant capture
        if ((piece == Piece.WhitePawn || piece == Piece.BlackPawn) &&
            position.EnPassantSquare == toSquare)
        {
            var capturedPawnRank = piece == Piece.WhitePawn ? '5' : '4';
            position.SetPieceAt($"{toSquare[0]}{capturedPawnRank}", Piece.None);
        }

        // Update en passant square
        if ((piece == Piece.WhitePawn && fromSquare[1] == '2' && toSquare[1] == '4') ||
            (piece == Piece.BlackPawn && fromSquare[1] == '7' && toSquare[1] == '5'))
        {
            var epRank = piece == Piece.WhitePawn ? '3' : '6';
            position.EnPassantSquare = $"{fromSquare[0]}{epRank}";
        }
        else
        {
            position.EnPassantSquare = null;
        }

        // Update castling rights if rook moved
        if (fromSquare == "a1" || toSquare == "a1") position.WhiteQueensideCastle = false;
        if (fromSquare == "h1" || toSquare == "h1") position.WhiteKingsideCastle = false;
        if (fromSquare == "a8" || toSquare == "a8") position.BlackQueensideCastle = false;
        if (fromSquare == "h8" || toSquare == "h8") position.BlackKingsideCastle = false;

        // Toggle turn
        position.WhiteToMove = !position.WhiteToMove;
        if (!position.WhiteToMove) position.FullmoveNumber++;

        // Update FEN
        _currentFen = FenParser.ToFen(position);
        _fenInput = _currentFen;
        _coachMessage = $"Move played: {move}";

        // Clear analysis on move
        _evaluation = null;
        _mateIn = null;
        _bestMove = null;
        _topMoves = null;
        _analysisDepth = 0;

        StateHasChanged();
    }

    private static Piece GetPromotionPiece(char promotion, bool isWhite) => promotion switch
    {
        'q' or 'Q' => isWhite ? Piece.WhiteQueen : Piece.BlackQueen,
        'r' or 'R' => isWhite ? Piece.WhiteRook : Piece.BlackRook,
        'b' or 'B' => isWhite ? Piece.WhiteBishop : Piece.BlackBishop,
        'n' or 'N' => isWhite ? Piece.WhiteKnight : Piece.BlackKnight,
        _ => isWhite ? Piece.WhiteQueen : Piece.BlackQueen
    };

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _coachMessage = $"Processing {file.Name}...";
        StateHasChanged();

        try
        {
            if (file.ContentType.StartsWith("image/"))
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var result = await ApiService.RecognizeBoardAsync(stream, file.Name);

                if (result?.Fen != null)
                {
                    // Normalize the FEN - vision service might return incomplete FEN
                    var fen = NormalizeFen(result.Fen);
                    var (isValid, error) = FenParser.Validate(fen);

                    if (!isValid)
                    {
                        _coachMessage = $"Invalid FEN from vision: {error}. Raw: {result.Fen}";
                        return;
                    }

                    _currentFen = fen;
                    _fenInput = fen;
                    _boardKey++;
                    _coachMessage = "Board recognized! Click Analyze to evaluate the position.";
                    StateHasChanged();
                    await TryIdentifyOpening();
                }
                else
                {
                    _coachMessage = "Could not recognize the chess board. Try a clearer image.";
                }
            }
            else if (file.Name.EndsWith(".pgn", StringComparison.OrdinalIgnoreCase))
            {
                using var streamReader = new StreamReader(file.OpenReadStream());
                var pgn = await streamReader.ReadToEndAsync();

                _coachMessage = "Analyzing PGN game... This may take a moment.";
                StateHasChanged();

                var analysis = await ApiService.AnalyzePgnAsync(pgn);
                if (analysis != null)
                {
                    _coachMessage = $"Game analyzed! White CPL: {analysis.WhiteAverageCentipawnLoss:F1}, Black CPL: {analysis.BlackAverageCentipawnLoss:F1}";
                }
            }
        }
        catch (Exception ex)
        {
            _coachMessage = $"Failed to process file: {ex.Message}";
        }

        StateHasChanged();
    }

    private void GenerateCoachMessage()
    {
        if (_evaluation == null && _mateIn == null)
        {
            _coachMessage = "Analysis complete.";
            return;
        }

        if (_mateIn.HasValue)
        {
            _coachMessage = _mateIn > 0
                ? $"Checkmate in {_mateIn}! White wins with perfect play."
                : $"Checkmate in {Math.Abs(_mateIn.Value)}! Black wins with perfect play.";
            return;
        }

        var eval = _evaluation ?? 0;
        _coachMessage = eval switch
        {
            > 3 => "White has a decisive advantage. Look for tactical strikes!",
            > 1.5 => "White has a clear advantage. Maintain pressure.",
            > 0.5 => "White has a slight edge. Small improvements matter.",
            > -0.5 => "Position is balanced. Both sides have chances.",
            > -1.5 => "Black has a slight edge. Small improvements matter.",
            > -3 => "Black has a clear advantage. Maintain pressure.",
            _ => "Black has a decisive advantage. Look for tactical strikes!"
        };
    }

    private string FormatEval(double? eval, int? mateIn)
    {
        if (mateIn.HasValue)
            return mateIn > 0 ? $"M{mateIn}" : $"M{Math.Abs(mateIn.Value)}";

        if (!eval.HasValue) return "0.00";

        var sign = eval >= 0 ? "+" : "";
        return $"{sign}{eval:F2}";
    }

    private int GetEvalBarWidth()
    {
        if (_mateIn.HasValue)
            return _mateIn > 0 ? 100 : 0;

        if (!_evaluation.HasValue) return 50;

        // Convert eval to percentage (sigmoid-like)
        var eval = Math.Clamp(_evaluation.Value, -5, 5);
        return (int)(50 + eval * 10);
    }

    private string GetEvalClass()
    {
        if (_mateIn > 0 || _evaluation > 0.5) return "positive";
        if (_mateIn < 0 || _evaluation < -0.5) return "negative";
        return "neutral";
    }

    /// <summary>
    /// Normalize FEN string - vision service might return incomplete FEN.
    /// Ensures we have all 6 parts: position, color, castling, en-passant, halfmove, fullmove.
    /// </summary>
    private static string NormalizeFen(string fen)
    {
        if (string.IsNullOrWhiteSpace(fen)) return FenParser.StartingPosition;

        var parts = fen.Trim().Split(' ');
        if (parts.Length == 0) return FenParser.StartingPosition;

        // Ensure we have all 6 parts
        var normalized = new string[6];
        normalized[0] = parts.Length > 0 ? parts[0] : "8/8/8/8/8/8/8/8";  // board
        normalized[1] = parts.Length > 1 ? parts[1] : "w";                // side to move
        normalized[2] = parts.Length > 2 ? parts[2] : "-";                // castling
        normalized[3] = parts.Length > 3 ? parts[3] : "-";                // en passant
        normalized[4] = parts.Length > 4 ? parts[4] : "0";                // halfmove clock
        normalized[5] = parts.Length > 5 ? parts[5] : "1";                // fullmove number

        return string.Join(" ", normalized);
    }

    private string GetCurrentTurn()
    {
        var position = FenParser.TryParse(_currentFen);
        return position?.WhiteToMove == true ? "White" : "Black";
    }

    private string GetMoveNumber()
    {
        var position = FenParser.TryParse(_currentFen);
        return position?.FullmoveNumber.ToString() ?? "1";
    }

    private string GetMaterialBalance()
    {
        var position = FenParser.TryParse(_currentFen);
        if (position == null) return "=";

        int whiteMaterial = 0;
        int blackMaterial = 0;

        for (int r = 0; r < 8; r++)
        {
            for (int f = 0; f < 8; f++)
            {
                var piece = position.Board[r, f];
                var value = piece switch
                {
                    Piece.WhiteQueen => 9,
                    Piece.WhiteRook => 5,
                    Piece.WhiteBishop => 3,
                    Piece.WhiteKnight => 3,
                    Piece.WhitePawn => 1,
                    Piece.BlackQueen => -9,
                    Piece.BlackRook => -5,
                    Piece.BlackBishop => -3,
                    Piece.BlackKnight => -3,
                    Piece.BlackPawn => -1,
                    _ => 0
                };
                if (value > 0) whiteMaterial += value;
                else blackMaterial += Math.Abs(value);
            }
        }

        var diff = whiteMaterial - blackMaterial;
        if (diff == 0) return "=";
        return diff > 0 ? $"+{diff}" : diff.ToString();
    }

    private string GetMaterialClass()
    {
        var balance = GetMaterialBalance();
        if (balance.StartsWith("+")) return "positive";
        if (balance.StartsWith("-")) return "negative";
        return "neutral";
    }
}
