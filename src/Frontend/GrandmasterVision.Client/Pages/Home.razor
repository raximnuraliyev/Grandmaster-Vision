@page "/"
@using GrandmasterVision.Client.Components
@using GrandmasterVision.Client.Services
@using GrandmasterVision.Core.Services
@inject ChessApiService ApiService
@inject LichessExplorerService ExplorerService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Grandmaster Vision - Professional Chess Analysis</PageTitle>

<div class="analysis-suite">
    <!-- Header Bar -->
    <div class="header-bar">
        <div class="header-logo">
            <div class="header-logo-icon">♔</div>
            <span>Grandmaster Vision</span>
        </div>
        <div class="header-controls">
            <button class="btn-icon" @onclick="() => _showSettings = true" title="Settings">
                ⚙️
            </button>
        </div>
    </div>

    <!-- Left Column: Board Section -->
    <div class="board-section">
        <!-- Top Player Banner (Black by default, White if flipped) -->
        <div class="player-banner">
            <div class="player-info">
                <div class="player-avatar @(_flipBoard ? "white" : "black")">
                    @(_flipBoard ? _whitePlayer.Name[0] : _blackPlayer.Name[0])
                </div>
                <div class="player-details">
                    <div class="player-name">@(_flipBoard ? _whitePlayer.Name : _blackPlayer.Name)</div>
                    <div class="player-rating">@(_flipBoard ? _whitePlayer.Rating : _blackPlayer.Rating)</div>
                </div>
                <div class="player-stats">
                    @{
                        var topMaterial = _flipBoard ? GetMaterialAdvantage(true) : GetMaterialAdvantage(false);
                    }
                    @if (topMaterial != 0)
                    {
                        <div class="material-advantage @(topMaterial > 0 ? "positive" : topMaterial < 0 ? "negative" : "neutral")">
                            @(topMaterial > 0 ? $"+{topMaterial}" : topMaterial.ToString())
                        </div>
                    }
                    <div class="captured-pieces">
                        @foreach (var piece in (_flipBoard ? _whiteCaptured : _blackCaptured))
                        {
                            <span>@piece</span>
                        }
                    </div>
                </div>
            </div>
            <div class="digital-clock">
                <div class="clock-display @(IsTopPlayerActive() ? "active" : "")">
                    @(_flipBoard ? FormatTime(_whiteTime) : FormatTime(_blackTime))
                </div>
            </div>
        </div>

        <!-- Chessboard -->
        <ChessBoard @key="_boardKey"
                    Fen="@_currentFen"
                    Evaluation="@_evaluation"
                    MateIn="@_mateIn"
                    BestMoveSan="@_bestMoveSan"
                    ArrowMode="@_arrowMode"
                    ShowThreatArrows="@_showThreatArrows"
                    CoachArrows="@_coachArrows"
                    ThreatArrows="@_threatArrows"
                    LastMoveFrom="@_lastMoveFrom"
                    LastMoveTo="@_lastMoveTo"
                    LastMoveClassification="@_lastMoveClassification"
                    ShowCoordinates="@_showCoordinates"
                    ShowMoveClassification="@_showMoveClassifications"
                    FlipBoard="@_flipBoard"
                    OnMove="HandleMove" />

        <!-- Bottom Player Banner (White by default, Black if flipped) -->
        <div class="player-banner">
            <div class="player-info">
                <div class="player-avatar @(_flipBoard ? "black" : "white")">
                    @(_flipBoard ? _blackPlayer.Name[0] : _whitePlayer.Name[0])
                </div>
                <div class="player-details">
                    <div class="player-name">@(_flipBoard ? _blackPlayer.Name : _whitePlayer.Name)</div>
                    <div class="player-rating">@(_flipBoard ? _blackPlayer.Rating : _whitePlayer.Rating)</div>
                </div>
                <div class="player-stats">
                    @{
                        var bottomMaterial = _flipBoard ? GetMaterialAdvantage(false) : GetMaterialAdvantage(true);
                    }
                    @if (bottomMaterial != 0)
                    {
                        <div class="material-advantage @(bottomMaterial > 0 ? "positive" : bottomMaterial < 0 ? "negative" : "neutral")">
                            @(bottomMaterial > 0 ? $"+{bottomMaterial}" : bottomMaterial.ToString())
                        </div>
                    }
                    <div class="captured-pieces">
                        @foreach (var piece in (_flipBoard ? _blackCaptured : _whiteCaptured))
                        {
                            <span>@piece</span>
                        }
                    </div>
                </div>
            </div>
            <div class="digital-clock">
                <div class="clock-display @(IsBottomPlayerActive() ? "active" : "")">
                    @(_flipBoard ? FormatTime(_blackTime) : FormatTime(_whiteTime))
                </div>
            </div>
        </div>

        <!-- Board Control Bar -->
        <div class="board-control-bar">
            <button class="control-btn" @onclick="FlipBoard" title="Flip Board">
                ⟲ Flip
            </button>
            <button class="control-btn" @onclick="ResetBoard" title="Reset Position">
                ↺ Reset
            </button>
            <button class="control-btn" @onclick="() => _showImageUpload = true" title="Import Screenshot">
                📷 Import
            </button>
            <button class="control-btn primary" @onclick="Analyze" disabled="@_isAnalyzing" title="Analyze Position">
                @if (_isAnalyzing)
                {
                    <span class="spinner" style="width:16px;height:16px;margin-right:8px;"></span>
                    <span>Analyzing...</span>
                }
                else
                {
                    <span>⚡ Analyze</span>
                }
            </button>
        </div>

        <!-- Image Upload Drop Zone -->
        @if (_showImageUpload)
        {
            <div class="image-upload-overlay" @onclick="() => _showImageUpload = false">
                <div class="image-upload-modal" @onclick:stopPropagation>
                    <div class="image-upload-header">
                        <h3>Import Chess Position from Image</h3>
                        <button class="close-btn" @onclick="() => _showImageUpload = false">×</button>
                    </div>
                    <div class="image-drop-zone @(_isDraggingImage ? "dragging" : "")"
                         @ondragenter="HandleDragEnter"
                         @ondragleave="HandleDragLeave"
                         @ondragover:preventDefault
                         @ondrop="HandleImageDrop">
                        @if (_isProcessingImage)
                        {
                            <div class="processing-indicator">
                                <div class="spinner"></div>
                                <p>Analyzing image...</p>
                            </div>
                        }
                        else
                        {
                            <div class="drop-zone-content">
                                <span class="drop-icon">📸</span>
                                <p>Drag & drop a screenshot here</p>
                                <p class="drop-hint">or click to browse</p>
                                <InputFile OnChange="HandleImageUpload" accept="image/*" class="file-input" />
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_imageUploadError))
                    {
                        <div class="upload-error">@_imageUploadError</div>
                    }
                    @if (!string.IsNullOrEmpty(_recognizedFen))
                    {
                        <div class="recognized-fen">
                            <strong>Detected FEN:</strong>
                            <code>@_recognizedFen</code>
                            <button class="btn btn-primary" @onclick="ApplyRecognizedFen">Apply to Board</button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Right Column: Analysis Sidebar -->
    <div class="analysis-sidebar">
        <!-- Tabs -->
        <div class="sidebar-tabs">
            <button class="tab-button @(_activeTab == "analysis" ? "active" : "")"
                    @onclick='() => _activeTab = "analysis"'>
                Analysis
            </button>
            <button class="tab-button @(_activeTab == "games" ? "active" : "")"
                    @onclick='() => _activeTab = "games"'>
                Games
            </button>
            <button class="tab-button @(_activeTab == "explore" ? "active" : "")"
                    @onclick='() => _activeTab = "explore"'>
                Explore
            </button>
        </div>

        <!-- Sidebar Content -->
        <div class="sidebar-content">
            @if (_activeTab == "analysis")
            {
                <!-- Analyzing Indicator -->
                @if (_isAnalyzing)
                {
                    <div class="analyzing-indicator" style="margin: 12px;">
                        <div class="spinner"></div>
                        <span class="analyzing-text">
                            Stockfish analyzing... <strong>Depth @_analysisDepth</strong>
                        </span>
                    </div>
                }

                <!-- Engine Lines -->
                @if (_topMoves != null && _topMoves.Count > 0)
                {
                    <div class="engine-lines">
                        <div class="engine-header">
                            <span class="engine-title">
                                <span>♛</span> Engine Lines
                            </span>
                            <span class="engine-depth">depth = @_analysisDepth</span>
                        </div>
                        @foreach (var line in _topMoves.Take(5))
                        {
                            var evalClass = line.MateIn.HasValue
                                ? (line.MateIn > 0 ? "mate" : "mate black")
                                : (line.Evaluation >= 0 ? "positive" : "negative");

                            <div class="engine-line" @onclick="() => PlayEngineLine(line)">
                                <span class="line-eval @evalClass">
                                    @FormatEval(line.Evaluation, line.MateIn)
                                </span>
                                <span class="line-moves">
                                    @(line.Line ?? line.Move)
                                </span>
                            </div>
                        }
                    </div>
                }

                <!-- Opening Explorer -->
                @if (_opening != null)
                {
                    <div class="opening-explorer">
                        <div class="opening-eco">@_opening.Eco</div>
                        <div class="opening-name">@_opening.Name</div>
                    </div>
                }

                <!-- Move Ledger -->
                <div class="move-ledger">
                    <div class="move-ledger-inner">
                        @for (int i = 0; i < _moveHistory.Count; i += 2)
                        {
                            var moveNumber = (i / 2) + 1;
                            var whiteIndex = i;
                            var blackIndex = i + 1;

                            <div class="move-number">@moveNumber.</div>

                            <div class="move-cell @(_currentMoveIndex == whiteIndex ? "active" : "")"
                                 @onclick="() => GoToMove(whiteIndex)">
                                @if (_moveHistory[whiteIndex].Classification != MoveClassification.None)
                                {
                                    <span class="move-classification @GetClassificationClass(_moveHistory[whiteIndex].Classification)"></span>
                                }
                                @_moveHistory[whiteIndex].San
                            </div>

                            @if (blackIndex < _moveHistory.Count)
                            {
                                <div class="move-cell @(_currentMoveIndex == blackIndex ? "active" : "")"
                                     @onclick="() => GoToMove(blackIndex)">
                                    @if (_moveHistory[blackIndex].Classification != MoveClassification.None)
                                    {
                                        <span class="move-classification @GetClassificationClass(_moveHistory[blackIndex].Classification)"></span>
                                    }
                                    @_moveHistory[blackIndex].San
                                </div>
                            }
                            else
                            {
                                <div class="move-cell empty"></div>
                            }
                        }
                    </div>
                </div>
            }
            else if (_activeTab == "games")
            {
                <div style="padding: 24px; text-align: center; color: var(--text-muted);">
                    <p style="font-size: 48px; margin-bottom: 16px;">📚</p>
                    <p>Game database coming soon</p>
                </div>
            }
            else if (_activeTab == "explore")
            {
                <div class="explore-content">
                    @if (_isLoadingExplorer)
                    {
                        <div class="explore-loading">
                            <div class="spinner"></div>
                            <p>Loading opening data...</p>
                        </div>
                    }
                    else if (_explorerData == null || !_explorerData.Moves.Any())
                    {
                        <div class="explore-empty">
                            <p style="font-size: 36px;">📖</p>
                            <p>No opening data found for this position</p>
                            <p style="font-size: 12px;">Try an earlier position from the opening</p>
                        </div>
                    }
                    else
                    {
                        @if (_explorerData.Opening != null)
                        {
                            <div class="opening-explorer">
                                <div class="opening-eco">@_explorerData.Opening.Eco</div>
                                <div class="opening-name">@_explorerData.Opening.Name</div>
                            </div>
                        }

                        <div style="padding: var(--spacing-sm); background: var(--bg-tertiary); font-size: 11px; color: var(--text-muted);">
                            @_explorerData.TotalGames.ToString("N0") games from masters database
                        </div>

                        <table class="explore-table">
                            <thead>
                                <tr>
                                    <th>Move</th>
                                    <th>Games</th>
                                    <th>Results</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var move in _explorerData.Moves.Take(5))
                                {
                                    <tr @onclick="() => PlayExplorerMove(move.Uci)">
                                        <td class="explore-move">@move.San</td>
                                        <td class="explore-games">@move.TotalGames.ToString("N0")</td>
                                        <td>
                                            <div class="explore-stats">
                                                <div class="stat-white" style="width: @(move.WhitePercentage)%"></div>
                                                <div class="stat-draw" style="width: @(move.DrawPercentage)%"></div>
                                                <div class="stat-black" style="width: @(move.BlackPercentage)%"></div>
                                            </div>
                                            <div class="explore-percentages">
                                                <span>@move.WhitePercentage.ToString("F0")%</span>
                                                <span>@move.DrawPercentage.ToString("F0")%</span>
                                                <span>@move.BlackPercentage.ToString("F0")%</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }

            <!-- FEN Input (always visible in analysis tab) -->
            @if (_activeTab == "analysis")
            {
                <div style="padding: 12px; border-top: 1px solid var(--border); margin-top: auto;">
                    <div style="display: flex; gap: 8px;">
                        <input type="text"
                               class="input"
                               style="flex: 1; font-size: 11px;"
                               @bind="_fenInput"
                               placeholder="Paste FEN notation..." />
                        <button class="btn btn-secondary" style="padding: 8px 12px;" @onclick="LoadFen">
                            Load
                        </button>
                    </div>
                </div>
            }
        </div>

        <!-- Navigation Footer -->
        <div class="sidebar-footer">
            <button class="nav-btn" @onclick="GoToFirstMove" disabled="@(_currentMoveIndex <= 0)" title="First Move">
                ⏮
            </button>
            <button class="nav-btn" @onclick="GoToPreviousMove" disabled="@(_currentMoveIndex <= 0)" title="Previous">
                ⏪
            </button>
            <button class="nav-btn play" @onclick="ToggleAutoplay" title="@(_isAutoplaying ? "Pause" : "Play")">
                @(_isAutoplaying ? "⏸" : "▶")
            </button>
            <button class="nav-btn" @onclick="GoToNextMove" disabled="@(_currentMoveIndex >= _moveHistory.Count - 1)" title="Next">
                ⏩
            </button>
            <button class="nav-btn" @onclick="GoToLastMove" disabled="@(_currentMoveIndex >= _moveHistory.Count - 1)" title="Last Move">
                ⏭
            </button>
        </div>
    </div>
</div>

<!-- Settings Modal -->
@if (_showSettings)
{
    <div class="modal-overlay" @onclick="() => _showSettings = false">
        <div class="settings-panel" @onclick:stopPropagation>
            <div class="settings-header">
                <h2 class="settings-title">Analysis Settings</h2>
                <button class="settings-close" @onclick="() => _showSettings = false">×</button>
            </div>

            <div class="setting-group">
                <label class="setting-label">Show Arrows</label>
                <p class="setting-description">Control which engine arrows appear on the board</p>
                <select class="setting-select" @bind="_arrowModeString">
                    <option value="BestMove">Best Move Only</option>
                    <option value="Coach">Coach Visualizations</option>
                    <option value="Both">Both</option>
                    <option value="None">None</option>
                </select>
            </div>

            <div class="setting-group">
                <div class="toggle-row">
                    <span class="toggle-label">Show Threat Arrows</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_showThreatArrows" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <div class="setting-group">
                <div class="toggle-row">
                    <span class="toggle-label">Move Classification Icons</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_showMoveClassifications" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <div class="setting-group">
                <div class="toggle-row">
                    <span class="toggle-label">Show Coordinates</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_showCoordinates" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <div class="setting-group">
                <div class="toggle-row">
                    <span class="toggle-label">Autoplay Moves</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_autoplayEnabled" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                @if (_autoplayEnabled)
                {
                    <select class="setting-select" style="margin-top: 8px;" @bind="_autoplayDelayMs">
                        <option value="500">0.5 seconds</option>
                        <option value="1000">1 second</option>
                        <option value="1500">1.5 seconds</option>
                        <option value="2000">2 seconds</option>
                        <option value="3000">3 seconds</option>
                    </select>
                }
            </div>
        </div>
    </div>
}

@code {
    // State
    private string _currentFen = FenParser.StartingPosition;
    private string _fenInput = FenParser.StartingPosition;
    private bool _flipBoard = false;
    private bool _isAnalyzing = false;
    private bool _isAutoplaying = false;
    private int _analysisDepth = 0;
    private int _boardKey = 0;
    private string _activeTab = "analysis";
    private bool _showSettings = false;

    // Image Upload State
    private bool _showImageUpload = false;
    private bool _isDraggingImage = false;
    private bool _isProcessingImage = false;
    private string? _imageUploadError;
    private string? _recognizedFen;

    // Arrow & Visualization Settings
    private ArrowMode _arrowMode = ArrowMode.BestMove;
    private string _arrowModeString
    {
        get => _arrowMode.ToString();
        set => _arrowMode = Enum.Parse<ArrowMode>(value);
    }
    private bool _showThreatArrows = false;
    private bool _showMoveClassifications = true;
    private bool _showCoordinates = true;
    private bool _autoplayEnabled = false;
    private int _autoplayDelayMs = 1500;
    private string _bestMoveSan = "";
    private List<ArrowData>? _coachArrows;
    private List<ArrowData>? _threatArrows;

    // Last Move
    private string? _lastMoveFrom;
    private string? _lastMoveTo;
    private MoveClassification _lastMoveClassification = MoveClassification.None;

    // Analysis Data
    private double? _evaluation;
    private int? _mateIn;
    private BestMoveResponse? _bestMove;
    private List<MoveAnalysis>? _topMoves;
    private OpeningInfo? _opening;

    // Move History
    private List<MoveRecord> _moveHistory = new();
    private int _currentMoveIndex = -1;

    // Player Info
    private PlayerInfo _whitePlayer = new() { Name = "You", Rating = "1900" };
    private PlayerInfo _blackPlayer = new() { Name = "Stockfish", Rating = "3200" };
    private TimeSpan _whiteTime = TimeSpan.FromMinutes(10);
    private TimeSpan _blackTime = TimeSpan.FromMinutes(10);
    private List<char> _whiteCaptured = new();
    private List<char> _blackCaptured = new();

    // Opening Explorer State
    private OpeningExplorerResponse? _explorerData;
    private bool _isLoadingExplorer = false;
    private string? _lastExploredFen;

    // Chess Clock State
    private System.Threading.Timer? _clockTimer;
    private bool _clockRunning = false;
    private DateTime _lastTickTime;

    // Coach State
    private string? _coachExplanation;
    private MoveClassification _lastMoveEvalClassification = MoveClassification.None;
    private double? _evalBeforeMove;
    private double? _evalAfterMove;

    // =====================================================
    // LIFECYCLE
    // =====================================================

    protected override void OnInitialized()
    {
        // Initialize with sample moves for demo
        _moveHistory = new List<MoveRecord>
        {
            new() { Number = 1, IsWhiteMove = true, San = "e4", Fen = "rnbqkbnr/pppppppp/8/8/4P3/8/PPPP1PPP/RNBQKBNR b KQkq e3 0 1", Classification = MoveClassification.Best },
            new() { Number = 1, IsWhiteMove = false, San = "c5", Fen = "rnbqkbnr/pp1ppppp/8/2p5/4P3/8/PPPP1PPP/RNBQKBNR w KQkq c6 0 2" },
            new() { Number = 2, IsWhiteMove = true, San = "Nf3", Fen = "rnbqkbnr/pp1ppppp/8/2p5/4P3/5N2/PPPP1PPP/RNBQKB1R b KQkq - 1 2", Classification = MoveClassification.Best },
            new() { Number = 2, IsWhiteMove = false, San = "d6", Fen = "rnbqkbnr/pp2pppp/3p4/2p5/4P3/5N2/PPPP1PPP/RNBQKB1R w KQkq - 0 3" },
            new() { Number = 3, IsWhiteMove = true, San = "d4", Fen = "rnbqkbnr/pp2pppp/3p4/2p5/3PP3/5N2/PPP2PPP/RNBQKB1R b KQkq d3 0 3" },
            new() { Number = 3, IsWhiteMove = false, San = "cxd4", Fen = "rnbqkbnr/pp2pppp/3p4/8/3pP3/5N2/PPP2PPP/RNBQKB1R w KQkq - 0 4" },
            new() { Number = 4, IsWhiteMove = true, San = "Nxd4", Fen = "rnbqkbnr/pp2pppp/3p4/8/3NP3/8/PPP2PPP/RNBQKB1R b KQkq - 0 4", Classification = MoveClassification.Best },
        };
        _currentMoveIndex = _moveHistory.Count - 1;
        _currentFen = _moveHistory[_currentMoveIndex].Fen;
        _opening = new OpeningInfo { Eco = "B54", Name = "Sicilian Defense: Open Variation" };
    }

    // =====================================================
    // BOARD ACTIONS
    // =====================================================

    private void FlipBoard()
    {
        _flipBoard = !_flipBoard;
    }

    private void ResetBoard()
    {
        _currentFen = FenParser.StartingPosition;
        _fenInput = FenParser.StartingPosition;
        _evaluation = null;
        _mateIn = null;
        _bestMove = null;
        _topMoves = null;
        _analysisDepth = 0;
        _bestMoveSan = "";
        _lastMoveFrom = null;
        _lastMoveTo = null;
        _moveHistory.Clear();
        _currentMoveIndex = -1;
        _coachArrows = null;
        _threatArrows = null;
        _boardKey++;
        ResetClocks();
        StateHasChanged();
    }

    // =====================================================
    // IMAGE UPLOAD / COMPUTER VISION
    // =====================================================

    private void HandleDragEnter()
    {
        _isDraggingImage = true;
    }

    private void HandleDragLeave()
    {
        _isDraggingImage = false;
    }

    private async Task HandleImageDrop(DragEventArgs e)
    {
        _isDraggingImage = false;
        // The actual file handling is done by InputFile component
        // This just provides visual feedback
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // Validate file type
        if (!file.ContentType.StartsWith("image/"))
        {
            _imageUploadError = "Please upload an image file (PNG, JPG, etc.)";
            return;
        }

        // Max 10MB
        if (file.Size > 10 * 1024 * 1024)
        {
            _imageUploadError = "Image too large. Maximum size is 10MB.";
            return;
        }

        _isProcessingImage = true;
        _imageUploadError = null;
        _recognizedFen = null;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var result = await ApiService.RecognizeBoardAsync(stream, file.Name);

            if (result != null && result.Valid && !string.IsNullOrEmpty(result.Fen))
            {
                _recognizedFen = result.Fen;
            }
            else
            {
                _imageUploadError = "Could not recognize chess position in the image. Please try a clearer screenshot.";
            }
        }
        catch (HttpRequestException ex)
        {
            _imageUploadError = $"Vision service unavailable: {ex.Message}";
        }
        catch (Exception ex)
        {
            _imageUploadError = $"Error processing image: {ex.Message}";
        }
        finally
        {
            _isProcessingImage = false;
            StateHasChanged();
        }
    }

    private async Task ApplyRecognizedFen()
    {
        if (string.IsNullOrEmpty(_recognizedFen)) return;

        var (isValid, error) = FenParser.Validate(_recognizedFen);
        if (!isValid)
        {
            _imageUploadError = $"Invalid FEN: {error}";
            return;
        }

        _currentFen = _recognizedFen;
        _fenInput = _recognizedFen;
        _showImageUpload = false;
        _recognizedFen = null;
        _boardKey++;

        // Clear previous analysis
        _evaluation = null;
        _mateIn = null;
        _bestMoveSan = "";
        _coachArrows = null;
        _threatArrows = null;
        _moveHistory.Clear();
        _currentMoveIndex = -1;

        StateHasChanged();
        await TryIdentifyOpening();
    }

    private async Task LoadFen()
    {
        var (isValid, error) = FenParser.Validate(_fenInput);
        if (!isValid)
        {
            // Could show toast notification here
            return;
        }

        _currentFen = _fenInput;
        _boardKey++;
        _evaluation = null;
        _bestMoveSan = "";
        StateHasChanged();

        await TryIdentifyOpening();
    }

    // =====================================================
    // ANALYSIS
    // =====================================================

    private async Task Analyze()
    {
        if (_isAnalyzing) return;

        _isAnalyzing = true;
        _analysisDepth = 0;
        _coachArrows = null;
        _threatArrows = null;
        StateHasChanged();

        try
        {
            var topMovesTask = ApiService.GetTopMovesAsync(_currentFen, 5, 25);
            var bestMoveTask = ApiService.GetBestMoveAsync(_currentFen, 25);
            var openingTask = TryIdentifyOpening();

            await Task.WhenAll(topMovesTask, bestMoveTask, openingTask);

            _topMoves = await topMovesTask;
            _bestMove = await bestMoveTask;

            if (_bestMove != null)
            {
                _evaluation = _bestMove.Evaluation;
                _mateIn = _bestMove.MateIn;
                _analysisDepth = _bestMove.Depth;
                _bestMoveSan = _bestMove.BestMove ?? "";
            }

            // Populate coach arrows (2nd and 3rd best moves)
            if (_topMoves != null && _topMoves.Count > 1)
            {
                _coachArrows = new List<ArrowData>();
                foreach (var move in _topMoves.Skip(1).Take(2))
                {
                    if (!string.IsNullOrEmpty(move.Move) && move.Move.Length >= 4)
                    {
                        _coachArrows.Add(new ArrowData
                        {
                            FromSquare = move.Move.Substring(0, 2),
                            ToSquare = move.Move.Substring(2, 2),
                            Type = ArrowType.Alternative
                        });
                    }
                }
            }

            // Populate threat arrows by analyzing opponent's response
            await PopulateThreatArrows();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Analysis error: {ex.Message}");
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Analyzes the position after the best move to find opponent's threats
    /// </summary>
    private async Task PopulateThreatArrows()
    {
        if (string.IsNullOrEmpty(_bestMoveSan) || _bestMoveSan.Length < 4) return;

        try
        {
            // Get the position after applying the best move to find opponent's response
            var position = FenParser.TryParse(_currentFen);
            if (position == null) return;

            // Apply best move to get resulting position
            var from = _bestMoveSan.Substring(0, 2);
            var to = _bestMoveSan.Substring(2, 2);
            var piece = position.GetPieceAt(from);
            if (piece == Piece.None) return;

            position.SetPieceAt(from, Piece.None);
            position.SetPieceAt(to, piece);
            position.WhiteToMove = !position.WhiteToMove;

            var newFen = FenParser.ToFen(position);

            // Get opponent's best response (the threat)
            var threatResponse = await ApiService.GetBestMoveAsync(newFen, 15);
            if (threatResponse?.BestMove != null && threatResponse.BestMove.Length >= 4)
            {
                _threatArrows = new List<ArrowData>
                {
                    new ArrowData
                    {
                        FromSquare = threatResponse.BestMove.Substring(0, 2),
                        ToSquare = threatResponse.BestMove.Substring(2, 2),
                        Type = ArrowType.Threat
                    }
                };
            }
        }
        catch
        {
            // Silently fail - threat analysis is optional
        }
    }

    private async Task TryIdentifyOpening()
    {
        try
        {
            _opening = await ApiService.IdentifyOpeningAsync(_currentFen);
        }
        catch
        {
            _opening = null;
        }
    }

    // =====================================================
    // MOVE HANDLING
    // =====================================================

    private async Task HandleMove(string move)
    {
        var position = FenParser.TryParse(_currentFen);
        if (position == null) return;

        if (move.Length < 4) return;

        var fromSquare = move.Substring(0, 2);
        var toSquare = move.Substring(2, 2);

        var piece = position.GetPieceAt(fromSquare);
        if (piece == Piece.None) return;

        // Apply move (simplified)
        position.SetPieceAt(fromSquare, Piece.None);
        position.SetPieceAt(toSquare, piece);
        position.WhiteToMove = !position.WhiteToMove;
        if (!position.WhiteToMove) position.FullmoveNumber++;

        _currentFen = FenParser.ToFen(position);
        _fenInput = _currentFen;
        _lastMoveFrom = fromSquare;
        _lastMoveTo = toSquare;

        // Add to history
        var san = GetSimpleSan(piece, fromSquare, toSquare);
        _moveHistory.Add(new MoveRecord
        {
            Number = position.FullmoveNumber,
            IsWhiteMove = position.WhiteToMove,
            San = san,
            Uci = move,
            Fen = _currentFen
        });
        _currentMoveIndex = _moveHistory.Count - 1;

        // Clear analysis
        _evaluation = null;
        _mateIn = null;
        _bestMoveSan = "";
        _analysisDepth = 0;

        StateHasChanged();
        await TryIdentifyOpening();
    }

    private string GetSimpleSan(Piece piece, string from, string to)
    {
        var pieceChar = piece switch
        {
            Piece.WhiteKing or Piece.BlackKing => "K",
            Piece.WhiteQueen or Piece.BlackQueen => "Q",
            Piece.WhiteRook or Piece.BlackRook => "R",
            Piece.WhiteBishop or Piece.BlackBishop => "B",
            Piece.WhiteKnight or Piece.BlackKnight => "N",
            _ => ""
        };
        return $"{pieceChar}{to}";
    }

    private void PlayEngineLine(MoveAnalysis line)
    {
        if (!string.IsNullOrEmpty(line.Move) && line.Move.Length >= 4)
        {
            var from = line.Move.Substring(0, 2);
            var to = line.Move.Substring(2, 2);
            _ = HandleMove(line.Move);
        }
    }

    // =====================================================
    // NAVIGATION
    // =====================================================

    private void GoToMove(int index)
    {
        if (index >= 0 && index < _moveHistory.Count)
        {
            _currentMoveIndex = index;
            _currentFen = _moveHistory[index].Fen;

            if (index > 0)
            {
                var prevMove = _moveHistory[index];
                _lastMoveFrom = prevMove.Uci?.Substring(0, 2);
                _lastMoveTo = prevMove.Uci?.Substring(2, 2);
                _lastMoveClassification = prevMove.Classification;
            }
            else
            {
                _lastMoveFrom = null;
                _lastMoveTo = null;
            }

            _boardKey++;
            _evaluation = null;
            _bestMoveSan = "";
            StateHasChanged();
        }
    }

    private void GoToFirstMove() => GoToMove(0);
    private void GoToPreviousMove() => GoToMove(_currentMoveIndex - 1);
    private void GoToNextMove() => GoToMove(_currentMoveIndex + 1);
    private void GoToLastMove() => GoToMove(_moveHistory.Count - 1);

    private void ToggleAutoplay()
    {
        _isAutoplaying = !_isAutoplaying;
        if (_isAutoplaying)
        {
            _ = RunAutoplay();
        }
    }

    private async Task RunAutoplay()
    {
        while (_isAutoplaying && _currentMoveIndex < _moveHistory.Count - 1)
        {
            await Task.Delay(_autoplayDelayMs);
            if (_isAutoplaying)
            {
                GoToNextMove();
            }
        }
        _isAutoplaying = false;
        StateHasChanged();
    }

    // =====================================================
    // HELPERS
    // =====================================================

    private string FormatEval(double? eval, int? mateIn)
    {
        if (mateIn.HasValue)
            return mateIn > 0 ? $"+M{mateIn}" : $"-M{Math.Abs(mateIn.Value)}";
        if (!eval.HasValue)
            return "0.00";
        var sign = eval >= 0 ? "+" : "";
        return $"{sign}{eval:F2}";
    }

    private int GetMaterialAdvantage(bool forWhite)
    {
        var position = FenParser.TryParse(_currentFen);
        if (position == null) return 0;

        int whiteMaterial = 0;
        int blackMaterial = 0;

        for (int r = 0; r < 8; r++)
        {
            for (int f = 0; f < 8; f++)
            {
                var piece = position.Board[r, f];
                var value = piece switch
                {
                    Piece.WhiteQueen => 9, Piece.WhiteRook => 5,
                    Piece.WhiteBishop => 3, Piece.WhiteKnight => 3, Piece.WhitePawn => 1,
                    Piece.BlackQueen => -9, Piece.BlackRook => -5,
                    Piece.BlackBishop => -3, Piece.BlackKnight => -3, Piece.BlackPawn => -1,
                    _ => 0
                };
                if (value > 0) whiteMaterial += value;
                else blackMaterial += Math.Abs(value);
            }
        }

        return forWhite ? whiteMaterial - blackMaterial : blackMaterial - whiteMaterial;
    }

    private string FormatTime(TimeSpan time)
    {
        return time.TotalHours >= 1
            ? $"{(int)time.TotalHours}:{time.Minutes:D2}:{time.Seconds:D2}"
            : $"{time.Minutes}:{time.Seconds:D2}";
    }

    private bool IsTopPlayerActive()
    {
        var position = FenParser.TryParse(_currentFen);
        if (position == null) return false;
        return _flipBoard ? position.WhiteToMove : !position.WhiteToMove;
