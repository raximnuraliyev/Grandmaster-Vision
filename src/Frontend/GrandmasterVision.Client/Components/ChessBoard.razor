@using GrandmasterVision.Core.Services

<div class="chess-board-container">
    <div class="chess-board">
        @for (int rank = 0; rank < 8; rank++)
        {
            @for (int file = 0; file < 8; file++)
            {
                var r = rank;
                var f = file;
                var square = GetSquareName(r, f);
                var piece = GetPieceAt(r, f);
                var isLight = (r + f) % 2 == 0;
                var isSelected = square == _selectedSquare;
                var isLastMove = square == _lastMoveFrom || square == _lastMoveTo;
                var showRankLabel = file == 0;
                var showFileLabel = rank == 7;
                var displayRank = FlipBoard ? (r + 1) : (8 - r);
                var displayFile = FlipBoard ? (char)('h' - f) : (char)('a' + f);

                <div class="square @(isLight ? "light" : "dark") @(isSelected ? "selected" : "") @(isLastMove ? "last-move" : "")"
                     @onclick="() => OnSquareClick(square)">

                    @if (showRankLabel)
                    {
                        <span class="coord rank @(isLight ? "dark-text" : "light-text")">@displayRank</span>
                    }
                    @if (showFileLabel)
                    {
                        <span class="coord file @(isLight ? "dark-text" : "light-text")">@displayFile</span>
                    }

                    @if (piece != Piece.None)
                    {
                        <img class="piece" src="images/pieces/@(GetPieceCode(piece)).svg" alt="@piece" draggable="false" />
                    }
                </div>
            }
        }
    </div>

    @if (Evaluation.HasValue || MateIn.HasValue)
    {
        <div class="eval-bar-vertical">
            <div class="eval-white" style="height: @GetEvalHeight()%"></div>
            <div class="eval-black"></div>
            <span class="eval-label">@FormatEval()</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Fen { get; set; } = FenParser.StartingPosition;
    [Parameter] public EventCallback<string> OnMove { get; set; }
    [Parameter] public EventCallback<string> OnFenChange { get; set; }
    [Parameter] public double? Evaluation { get; set; }
    [Parameter] public int? MateIn { get; set; }
    [Parameter] public bool FlipBoard { get; set; } = false;

    private ChessPosition _position = new();
    private string? _selectedSquare;
    private string? _lastMoveFrom;
    private string? _lastMoveTo;

    protected override void OnInitialized()
    {
        _position = FenParser.TryParse(Fen) ?? FenParser.Parse(FenParser.StartingPosition);
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Fen))
        {
            var parsed = FenParser.TryParse(Fen);
            if (parsed != null)
            {
                _position = parsed;
            }
        }
    }

    private Piece GetPieceAt(int rank, int file)
    {
        var r = FlipBoard ? 7 - rank : rank;
        var f = FlipBoard ? 7 - file : file;
        return _position.Board[r, f];
    }

    private string GetSquareName(int rank, int file)
    {
        var r = FlipBoard ? 7 - rank : rank;
        var f = FlipBoard ? 7 - file : file;
        return $"{(char)('a' + f)}{8 - r}";
    }

    private string GetPieceCode(Piece piece) => piece switch
    {
        Piece.WhiteKing => "wK",
        Piece.WhiteQueen => "wQ",
        Piece.WhiteRook => "wR",
        Piece.WhiteBishop => "wB",
        Piece.WhiteKnight => "wN",
        Piece.WhitePawn => "wP",
        Piece.BlackKing => "bK",
        Piece.BlackQueen => "bQ",
        Piece.BlackRook => "bR",
        Piece.BlackBishop => "bB",
        Piece.BlackKnight => "bN",
        Piece.BlackPawn => "bP",
        _ => ""
    };

    private void OnSquareClick(string square)
    {
        if (_selectedSquare == null)
        {
            var piece = GetPieceAtSquare(square);
            if (piece != Piece.None && IsCorrectColor(piece))
            {
                _selectedSquare = square;
            }
        }
        else if (_selectedSquare == square)
        {
            _selectedSquare = null;
        }
        else
        {
            MakeMove(_selectedSquare, square);
        }
    }

    private Piece GetPieceAtSquare(string square)
    {
        if (square.Length != 2) return Piece.None;

        int file = square[0] - 'a';
        int rank = 8 - (square[1] - '0');

        if (rank < 0 || rank > 7 || file < 0 || file > 7) return Piece.None;

        return _position.Board[rank, file];
    }

    private bool IsCorrectColor(Piece piece)
    {
        bool isWhitePiece = piece >= Piece.WhiteKing && piece <= Piece.WhitePawn;
        return isWhitePiece == _position.WhiteToMove;
    }

    private async void MakeMove(string from, string to)
    {
        var move = from + to;
        _lastMoveFrom = from;
        _lastMoveTo = to;
        _selectedSquare = null;

        await OnMove.InvokeAsync(move);
    }

    private string FormatEval()
    {
        if (MateIn.HasValue)
            return MateIn > 0 ? $"M{MateIn}" : $"M{Math.Abs(MateIn.Value)}";
        if (!Evaluation.HasValue) return "0.0";
        var sign = Evaluation >= 0 ? "+" : "";
        return $"{sign}{Evaluation:F1}";
    }

    private int GetEvalHeight()
    {
        if (MateIn.HasValue)
            return MateIn > 0 ? 100 : 0;
        if (!Evaluation.HasValue) return 50;
        var eval = Math.Clamp(Evaluation.Value, -10, 10);
        return (int)(50 + eval * 5);
    }
}
